# Backend Environment Variables
# Copy this to api/.env for local development

# LLM provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-flash-1.5

# API key rotation — add up to 5 keys; the system auto-rotates on rate-limit.
# LLM_API_KEY is accepted as a single-key fallback.
LLM_API_KEY_1=sk-or-v1-...
LLM_API_KEY_2=sk-or-v1-...
LLM_API_KEY_3=sk-or-v1-...
LLM_API_KEY_4=sk-or-v1-...
LLM_API_KEY_5=sk-or-v1-...

# Embedding Provider (required for corpus features)
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Database (required for corpus retrieval)
DATABASE_URL=postgresql://user:pass@localhost:5432/legaldoc

# Corpus Storage
# PUBLIC_CORPUS_BUCKET=legaldoc-corpus

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-project.vercel.app

# Retrieval Tuning
# RETRIEVAL_TOP_K=8
